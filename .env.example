# =====================================================
# SolGuard AI Environment Configuration (Example)
# -----------------------------------------------------
# Copy this file to .env before running the application.
# Replace all placeholder values with your own.
# Never commit your real .env file to GitHub.
# =====================================================

# =====================================================
# Application
# =====================================================
APP_NAME=SolGuard AI
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true

# =====================================================
# Server
# =====================================================
HOST=0.0.0.0
PORT=8000
WORKERS=2
ENABLE_DOCS=true

# =====================================================
# Solana RPC
# =====================================================
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_RPC_FALLBACK_URL=https://solana-api.projectserum.com
SOLANA_COMMITMENT=confirmed
SOLANA_TIMEOUT_SECONDS=10
SOLANA_MAX_RETRIES=3

# =====================================================
# Database
# =====================================================
DATABASE_URL=sqlite:///./solguard.db
DB_POOL_SIZE=5
DB_ECHO_SQL=false

# =====================================================
# Redis
# =====================================================
REDIS_URL=redis://localhost:6379/0
RATE_LIMIT_PER_MINUTE=60

# =====================================================
# AI Configuration
# =====================================================
AI_MODEL=basic-risk-engine
RISK_SCORE_THRESHOLD=70

# AI Providers (Optional)
OPENAI_API_KEY=
GEMINI_API_KEY=

# =====================================================
# Telegram Alerts
# =====================================================
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=REPLACE_WITH_TELEGRAM_BOT_TOKEN
TELEGRAM_CHAT_ID=REPLACE_WITH_CHAT_ID

# =====================================================
# Logging
# =====================================================
LOG_LEVEL=INFO
LOG_JSON=false

# =====================================================
# CORS
# =====================================================
ALLOWED_ORIGINS=*

# =====================================================
# Security
# =====================================================
SECRET_KEY=REPLACE_WITH_A_SECURE_RANDOM_SECRET
ADMIN_API_KEY=REPLACE_WITH_A_SECURE_ADMIN_API_KEY

# =====================================================
# Monitoring
# =====================================================
SENTRY_DSN=

# =====================================================
# Future Integrations (Optional)
# =====================================================
DISCORD_WEBHOOK_URL=
SLACK_WEBHOOK_URL=
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_USERNAME=
EMAIL_PASSWORD=
